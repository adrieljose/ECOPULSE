{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.6.0"
        },
        "*.php": {
            "runtime": "vercel-php@0.6.0"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ],
    "crons": [
        {
            "path": "/cron/predictive_alerts.php",
            "schedule": "0 16 * * *"
        },
        {
            "path": "/cron/diagnostics_engine.php",
            "schedule": "0 16 * * *"
        }
    ]
}